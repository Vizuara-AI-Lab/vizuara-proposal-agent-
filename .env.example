# ============================================================
# REQUIRED
# ============================================================

# Claude API key (Anthropic).
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# STORAGE — shared across your team. Pick ONE driver.
# ============================================================
# If SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, Supabase is used automatically.
# Otherwise the app falls back to the local filesystem (dev only — not shared).

# Option A — Supabase Storage (recommended for production).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Bucket must exist and be private. Create it once in the Supabase dashboard.
SUPABASE_BUCKET=proposals

# Force a driver (optional). Valid values: supabase | local
# PROPOSAL_STORAGE=supabase

# Option B — Local filesystem (dev only).
# Path where briefs, tex, and PDFs are written. Only used when no Supabase env is present.
# PROPOSAL_OUTPUT_DIR=/absolute/path/to/output

# ============================================================
# PDFLATEX COMPILATION — pick ONE strategy.
# ============================================================

# Strategy 1 — Bundled pdflatex inside the container (use the shipped Dockerfile).
# No env vars needed. Works out of the box if you deploy via Docker.

# Strategy 2 — External compile service (stateless HTTP endpoint that accepts
# { tex, assets } and returns application/pdf). Use this on Vercel or other
# serverless hosts that don't ship with pdflatex.
# COMPILE_SERVICE_URL=https://your-compile-service.example.com/compile
# COMPILE_SERVICE_TOKEN=optional-bearer-token

# Strategy 3 — Local pdflatex binary (dev on your laptop).
# macOS: brew install --cask basictex (after install: /Library/TeX/texbin/pdflatex)
# Ubuntu: apt install texlive-latex-recommended texlive-latex-extra
# PDFLATEX_BIN=/Library/TeX/texbin/pdflatex

# ============================================================
# GOOGLE MEET TRANSCRIPTS (optional but recommended)
# ============================================================
# A shared Drive folder containing all Meet recordings/transcripts.
# The folder must be shared with the service account's client_email as Viewer.
MEET_TRANSCRIPTS_FOLDER_ID=1ALDwgF3J1tY9mHkrkMqVPE5-Ms4gajkB
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
