# ---- REQUIRED ----
# Claude API key (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ---- PATHS (defaults point at Raj's local setup — override per machine) ----
# Where generated proposals land
PROPOSAL_OUTPUT_DIR=/absolute/path/to/output
# Vizuara style guide used when generating LaTeX
PROPOSAL_STYLE_GUIDE=/absolute/path/to/style.md
# Dir containing vizuara_logo.png (auto-seeded into each client's output folder)
PROPOSAL_ASSETS_DIR=/absolute/path/to/assets
# pdflatex binary (mac homebrew mactex default)
PDFLATEX_BIN=/Library/TeX/texbin/pdflatex

# ---- GOOGLE DRIVE TRANSCRIPTS (optional but recommended) ----
# Folder containing all Vizuara Meet recordings
MEET_TRANSCRIPTS_FOLDER_ID=1ALDwgF3J1tY9mHkrkMqVPE5-Ms4gajkB
# Service account JSON (single line). Folder must be shared with the
# service account's client_email as Viewer.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
